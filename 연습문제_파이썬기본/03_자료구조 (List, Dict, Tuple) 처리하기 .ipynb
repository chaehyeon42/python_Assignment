   "source": [
    "3-1. 5개의 숫자를 리스트에 저장하고 합계와 평균을 구하는 프로그램을 작성하세요."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "2db9ace2",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "숫자들:[10, 20, 30, 40, 50]\n",
      "합계:150\n",
      "평균:30.0\n"
     ]
    }
   ],
   "source": [
    "#숫자들: [10, 20, 30, 40, 50]\n",
    "\n",
    "num = [10, 20, 30, 40, 50]\n",
    "\n",
    "#숫자 합계\n",
    "num_sum = sum(num)\n",
    "\n",
    "#평균\n",
    "num_avg = num_sum/ len(num)\n",
    "\n",
    "print(f\"숫자들:{num}\")\n",
    "print(f\"합계:{num_sum}\")\n",
    "print(f\"평균:{num_avg}\")\n"
   ]
  }
 ],
